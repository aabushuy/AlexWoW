@page
@model LoginModel
@{
    ViewData["Title"] = "Вход";
}
<div class="panel panel-narrow">
    <h1>Вход</h1>
    <p class="lead">Войдите тем же email и паролем, что и в игре.</p>

    <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
        @{
            var modelErrors = ViewData.ModelState[string.Empty]?.Errors;
        }
        @if (modelErrors is { Count: > 0 })
        {
            <div class="alert alert-error" role="alert">
                @foreach (var e in modelErrors)
                {
                    <div>@e.ErrorMessage</div>
                }
            </div>
        }

        <div class="field">
            <label asp-for="Input.Email"></label>
            <input asp-for="Input.Email" autocomplete="email" autofocus />
            <span asp-validation-for="Input.Email" class="field-error"></span>
        </div>
        <div class="field">
            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" type="password" autocomplete="current-password" />
            <span asp-validation-for="Input.Password" class="field-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn">Войти</button>
        </div>
        <p class="form-hint">Нет аккаунта? <a asp-page="/Register">Зарегистрироваться</a></p>
    </form>
</div>
