@page
@using AlexWoW.Web.Services.Kanban
@model AlexWoW.Web.Pages.TicketModel
@{
    ViewData["Title"] = Model.IsNew ? "Новый тикет" : $"Тикет #{Model.Input.Id}";
    Layout = "_Layout"; // #2: без админ-сайдбара, но фиксированная ширина по центру (как обычные страницы)
    var projectsById = Model.Projects.ToDictionary(p => p.Id, p => p.Title);
}

<style>
    .tk-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; align-items: start; }
    .tk-field { margin-bottom: 12px; }
    .tk-field label { display: block; font-size: .82rem; opacity: .8; margin-bottom: 3px; }
    /* #4: контролы в стиле доски (тёмные, .92rem). Скоуп .tk-grid — блок комментариев не трогаем. */
    .tk-grid input[type=text], .tk-grid input[type=number], .tk-grid select, .tk-grid textarea {
        width: 100%; padding: 6px 8px; box-sizing: border-box; font-size: .92rem;
        background: #11151c; color: #e8e8e8; border: 1px solid #2a3550; border-radius: 4px; }
    .tk-grid textarea { min-height: 80px; resize: vertical; }
    .tk-save { height: 34px; padding: 0 18px; margin-top: 4px; border-radius: 4px; cursor: pointer;
        font-weight: 700; font-size: .92rem; color: #1a160b;
        background: linear-gradient(180deg, #ffe27a, #e8b73c 55%, #b07d1e); border: 1px solid #7a571a; }
    .tk-save:hover { filter: brightness(1.1); }
    .tk-row { display: flex; gap: 10px; }
    .tk-row > div { flex: 1; }
    .tk-comments { margin-top: 8px; }
    .tk-comment { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 8px; padding: 8px 10px; margin-bottom: 8px; }
    .tk-comment .meta { font-size: .75rem; opacity: .6; margin-bottom: 3px; }
    .tk-err { color: #ff6b6b; margin: 8px 0; }
    .tk-panel { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 14px; }
    .tk-arch-badge { display: inline-block; margin-left: 10px; font-size: .72rem; padding: 2px 8px;
                     border-radius: 10px; background: #455; color: #fff; vertical-align: middle; }
    .tk-meta-row { font-size: .78rem; opacity: .65; margin-top: 4px; }
</style>

<p><a asp-page="/Board">← К доске</a></p>
<h1>
    @(Model.IsNew ? "Новый тикет" : $"#{Model.Input.Id} · {Model.Input.Title}")
    @if (Model.IsArchive) { <span class="tk-arch-badge">в архиве</span> }
</h1>
@if (!Model.IsNew && Model.DoneAt is { } da)
{
    <div class="tk-meta-row">Закрыт: @da.ToString("yyyy-MM-dd HH:mm")</div>
}

@if (!Model.Configured)
{
    <div class="alert alert-warn">БД <code>project</code> не настроена.</div>
}
else
{
    @if (Model.Error != null)
    {
        <div class="tk-err">@Model.Error</div>
    }
    <form method="post" asp-page-handler="Save">
        <input type="hidden" asp-for="Input.Id" />
        <div class="tk-grid">
            <div>
                <div class="tk-field">
                    <label>Заголовок</label>
                    <input type="text" asp-for="Input.Title" />
                </div>
                <div class="tk-field">
                    <label>Описание</label>
                    <textarea asp-for="Input.Description"></textarea>
                </div>
                <div class="tk-field">
                    <label>Шаги тестирования</label>
                    <textarea asp-for="Input.TestSteps"></textarea>
                </div>
                <div class="tk-field">
                    <label>Ожидаемый результат</label>
                    <textarea asp-for="Input.ExpectedResult"></textarea>
                </div>
            </div>
            <div class="tk-panel">
                <div class="tk-row">
                    <div class="tk-field">
                        <label>Тип</label>
                        <select asp-for="Input.Type">
                            @foreach (var v in KanbanVocab.Types)
                            {
                                <option value="@v" selected="@(Model.Input.Type == v)">@v</option>
                            }
                        </select>
                    </div>
                    <div class="tk-field">
                        <label>Приоритет</label>
                        <select asp-for="Input.Priority">
                            @foreach (var v in KanbanVocab.Priorities)
                            {
                                <option value="@v" selected="@(Model.Input.Priority == v)">@v</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="tk-field">
                    <label>Статус</label>
                    <select asp-for="Input.Status">
                        @foreach (var v in KanbanVocab.Statuses)
                        {
                            <option value="@v" selected="@(Model.Input.Status == v)">@v</option>
                        }
                    </select>
                </div>
                <div class="tk-field">
                    <label>Проект (для Эпика)</label>
                    <select asp-for="Input.ProjectId">
                        <option value="">—</option>
                        @foreach (var p in Model.Projects)
                        {
                            <option value="@p.Id" selected="@(Model.Input.ProjectId == p.Id)">@p.Title</option>
                        }
                    </select>
                </div>
                <div class="tk-field">
                    <label>Эпик (для Задачи/Бага)</label>
                    <select asp-for="Input.EpicId">
                        <option value="">—</option>
                        @foreach (var e in Model.Epics)
                        {
                            var pn = e.ProjectId is { } pid && projectsById.TryGetValue(pid, out var t) ? t : "?";
                            <option value="@e.Id" selected="@(Model.Input.EpicId == e.Id)">[@pn] @e.Title</option>
                        }
                    </select>
                </div>
                <div class="tk-field">
                    <label>Исполнитель</label>
                    <select asp-for="Input.Assignee">
                        @foreach (var a in Model.Assignees)
                        {
                            <option value="@a" selected="@(Model.Input.Assignee == a)">@a</option>
                        }
                    </select>
                </div>
                <div class="tk-field">
                    <label>Тестировщик</label>
                    <select asp-for="Input.TesterGuid">
                        <option value="">—</option>
                        @foreach (var t in Model.Testers)
                        {
                            <option value="@t.Guid" selected="@(Model.Input.TesterGuid == t.Guid)">@t.Name (ур. @t.Level)</option>
                        }
                    </select>
                </div>
                <div class="tk-field">
                    <label><input type="checkbox" asp-for="Input.ClientCheck" /> Проверка на клиенте</label>
                </div>
                <div class="tk-field">
                    <label>Метки (через запятую)</label>
                    <input type="text" asp-for="Input.LabelsCsv" list="tk-all-labels"
                           placeholder="напр. dk, blocker, regression" />
                    <datalist id="tk-all-labels">
                        @foreach (var l in Model.AllLabels) { <option value="@l"></option> }
                    </datalist>
                </div>
                <button type="submit" class="tk-save">@(Model.IsNew ? "Создать" : "Сохранить")</button>
            </div>
        </div>
    </form>

    @if (!Model.IsNew)
    {
        <form method="post" asp-page-handler="Archive" style="margin-top:10px">
            <input type="hidden" name="id" value="@Model.Input.Id" />
            <input type="hidden" name="archive" value="@((!Model.IsArchive).ToString().ToLowerInvariant())" />
            <button type="submit" class="tk-save" style="background:linear-gradient(180deg,#5d6b85,#3d4d6e 55%,#2a3550); color:#e8e8e8; border-color:#2a3550">
                @(Model.IsArchive ? "Расхоронить" : "Архивировать")
            </button>
        </form>
    }

    @if (!Model.IsNew)
    {
        <h2>Комментарии</h2>
        <div class="tk-comments">
            @foreach (var c in Model.Comments)
            {
                <div class="tk-comment">
                    <div class="meta">@(string.IsNullOrEmpty(c.Author) ? "—" : c.Author) · @c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                    <div>@c.Body</div>
                </div>
            }
            @if (Model.Comments.Count == 0)
            {
                <p style="opacity:.6">Пока нет комментариев.</p>
            }
        </div>
        <form method="post" asp-page-handler="Comment">
            <input type="hidden" name="id" value="@Model.Input.Id" />
            <div class="tk-field">
                <textarea name="body" placeholder="Добавить комментарий…"></textarea>
            </div>
            <button type="submit">Добавить комментарий</button>
        </form>
    }
}
