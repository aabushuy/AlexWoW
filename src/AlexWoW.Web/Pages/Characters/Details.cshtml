@page "{guid:int}"
@model AlexWoW.Web.Pages.Characters.DetailsModel
@{
    var c = Model.Character;
    ViewData["Title"] = c.Name;
    var canChangeRace = Model.AvailableRaces.Count > 1;
}
<a class="back-link" asp-page="/Characters/Index">← К списку персонажей</a>

@if (!string.IsNullOrEmpty(Model.Flash))
{
    <div class="alert alert-ok" role="alert">@Model.Flash</div>
}

<partial name="_CharacterCard" model="Model.Card" />

<div class="panel">
    <h2>Внешность</h2>
    <p class="muted">Смена расы и пола. Раса — в пределах вашей фракции и класса.
        Не меняйте, находясь в игре: правка применится при следующем входе.</p>
    <p class="muted">Стоимость: смена расы — <strong class="coin"><span class="g">@Model.RaceChangeCostGold</span></strong> золота,
        смена пола — <strong class="coin"><span class="g">@Model.GenderChangeCostGold</span></strong> золота.
        Списывается только за изменённые поля. У вас: <strong class="coin"><span class="g">@GameData.SplitMoney(c.Money).Gold</span></strong> золота.</p>

    <form method="post" asp-page-handler="Appearance" asp-route-guid="@c.Guid">
        <div asp-validation-summary="ModelOnly" class="alert alert-error" role="alert"
             style="@(ViewData.ModelState.IsValid ? "display:none" : null)"></div>
        <div class="form-row">
            <div class="field">
                <label asp-for="Appearance.Race">Раса</label>
                <select asp-for="Appearance.Race" class="select" disabled="@(!canChangeRace)">
                    @foreach (var r in Model.AvailableRaces)
                    {
                        <option value="@r.Key">@r.Value</option>
                    }
                </select>
                @if (!canChangeRace)
                {
                    @* disabled-select не отправляется — шлём текущую расу скрытым полем, чтобы смена пола работала *@
                    <input type="hidden" asp-for="Appearance.Race" value="@c.Race" />
                    <span class="form-hint">Для вашего класса/фракции доступна только текущая раса.</span>
                }
                <span asp-validation-for="Appearance.Race" class="field-error"></span>
            </div>
            <div class="field">
                <label asp-for="Appearance.Gender">Пол</label>
                <select asp-for="Appearance.Gender" class="select">
                    @foreach (var g in GameData.AllGenders)
                    {
                        <option value="@g.Key">@g.Value</option>
                    }
                </select>
                <span asp-validation-for="Appearance.Gender" class="field-error"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn">Сохранить</button>
        </div>
    </form>
</div>

<div class="panel">
    <h2>Покупка золота</h2>
    <p class="muted">Демо-режим: золото начисляется без реальной оплаты (до @DetailsModel.MaxGoldPerPurchase
        за раз). Модель оплаты появится позже.</p>

    <form method="post" asp-page-handler="BuyGold" asp-route-guid="@c.Guid">
        <div class="form-row">
            <div class="field field-coin">
                <label asp-for="Gold.Amount">Сколько золота</label>
                <input asp-for="Gold.Amount" type="number" min="1" max="@DetailsModel.MaxGoldPerPurchase" />
                <span asp-validation-for="Gold.Amount" class="field-error"></span>
            </div>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn">Купить</button>
        </div>
    </form>
</div>
