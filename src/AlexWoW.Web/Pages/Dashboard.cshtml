@page
@model AlexWoW.Web.Pages.DashboardModel
@{
    ViewData["Title"] = "Дашборд";
    Layout = "_Layout";
    string PrioColor(string p) => p switch { "Blocker" => "#e53935", "Major" => "#fb8c00", _ => "#8a929c" };
    int Pct(int done, int total) => total == 0 ? 0 : (int)Math.Round(100.0 * done / total);
}

<style>
    .db-full { width: 100vw; margin-left: calc(50% - 50vw); padding: 0 24px; box-sizing: border-box; }
    .db-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin: 14px 0 22px; }
    .db-card { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.10); border-radius: 10px; padding: 14px; }
    .db-card .lbl { font-size: .82rem; opacity: .65; }
    .db-card .val { font-size: 1.8rem; font-weight: 700; margin-top: 4px; }
    .db-card.accent .val { color: #ffd54f; }
    .db-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; align-items: start; }
    .db-section { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 10px; padding: 14px; }
    .db-section h2 { margin: 0 0 12px; font-size: 1.05rem; }
    .db-proj { margin-bottom: 14px; }
    .db-proj > summary { cursor: pointer; padding: 6px 0; font-weight: 600; list-style: none; }
    .db-proj > summary::-webkit-details-marker { display: none; }
    .db-proj > summary::before { content: "▸ "; opacity: .6; transition: transform .15s; display: inline-block; }
    .db-proj[open] > summary::before { content: "▾ "; }
    .db-row { display: flex; align-items: center; gap: 10px; padding: 4px 0; font-size: .92rem; }
    .db-row .name { flex: 0 0 36%; opacity: .92; }
    .db-row .name a { color: #d6e6ff; text-decoration: none; }
    .db-row .name a:hover { text-decoration: underline; }
    .db-bar { flex: 1; height: 10px; background: rgba(255,255,255,.06); border-radius: 6px; overflow: hidden; }
    .db-bar > i { display: block; height: 100%; background: linear-gradient(90deg, #43a047, #66bb6a); }
    .db-num { flex: 0 0 100px; text-align: right; font-variant-numeric: tabular-nums; opacity: .85; font-size: .85rem; }
    .db-epic { padding-left: 18px; opacity: .92; }
    .db-tester { display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px dashed rgba(255,255,255,.06); }
    .db-tester:last-child { border-bottom: none; }
    .db-tester .cnt { color: #ffd54f; font-weight: 600; }
</style>

<div class="db-full">
<h1>Дашборд</h1>

@if (!Model.Configured)
{
    <div class="alert alert-warn">БД <code>project</code> не настроена.</div>
}
else
{
    var s = Model.Data.Summary;
    <div class="db-cards">
        <div class="db-card accent"><div class="lbl">Готовность</div><div class="val">@((int)Math.Round(s.PercentDone * 100))%</div></div>
        <div class="db-card"><div class="lbl">Открытых тикетов</div><div class="val">@s.OpenTotal</div></div>
        <div class="db-card"><div class="lbl">Blocker</div><div class="val" style="color:@PrioColor("Blocker")">@s.OpenBlocker</div></div>
        <div class="db-card"><div class="lbl">Major</div><div class="val" style="color:@PrioColor("Major")">@s.OpenMajor</div></div>
        <div class="db-card"><div class="lbl">Minor</div><div class="val" style="color:@PrioColor("Minor")">@s.OpenMinor</div></div>
        <div class="db-card"><div class="lbl">Багов</div><div class="val" style="color:#e53935">@s.OpenBugs</div></div>
        <div class="db-card"><div class="lbl">Задач</div><div class="val" style="color:#43a047">@s.OpenTasks</div></div>
    </div>

    <div class="db-grid">
        <section class="db-section">
            <h2>Прогресс по проектам</h2>
            @if (Model.Data.Projects.Count == 0)
            {
                <p style="opacity:.6">Проектов нет.</p>
            }
            else
            {
                @foreach (var p in Model.Data.Projects)
                {
                    var pTotal = p.Done + p.Open;
                    <details class="db-proj" open>
                        <summary>
                            <div class="db-row">
                                <span class="name"><a asp-page="/Board" asp-route-Project="@p.Id">@p.Title</a></span>
                                <span class="db-bar"><i style="width:@(Pct(p.Done, pTotal))%"></i></span>
                                <span class="db-num">@p.Done / @pTotal · @(Pct(p.Done, pTotal))%</span>
                            </div>
                        </summary>
                        @foreach (var e in p.Epics)
                        {
                            var eTotal = e.Done + e.Open;
                            <div class="db-row db-epic">
                                <span class="name"><a asp-page="/Board" asp-route-Project="@p.Id" asp-route-Epic="@e.Id">@e.Title</a></span>
                                <span class="db-bar"><i style="width:@(Pct(e.Done, eTotal))%"></i></span>
                                <span class="db-num">@e.Done / @eTotal · @(Pct(e.Done, eTotal))%</span>
                            </div>
                        }
                        @if (p.Epics.Count == 0)
                        {
                            <div class="db-row db-epic" style="opacity:.5">Эпиков нет.</div>
                        }
                    </details>
                }
            }
        </section>

        <section class="db-section">
            <h2>Тестеры (в Testing)</h2>
            @if (Model.Data.Testers.Count == 0)
            {
                <p style="opacity:.6">Все тестеры свободны.</p>
            }
            else
            {
                @foreach (var t in Model.Data.Testers)
                {
                    <div class="db-tester">
                        <span>@t.Name</span>
                        <span class="cnt">@t.InTesting</span>
                    </div>
                }
            }
        </section>
    </div>
}
</div>
