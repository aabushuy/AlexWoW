@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}
<div class="panel panel-narrow">
    <h1>Создать аккаунт</h1>
    <p class="lead">
        <strong>Email</strong> — для входа на этот сайт.
        <strong>Имя аккаунта</strong> — то, что вы вводите в поле «Учётная запись» игрового клиента
        (только латиница и цифры — клиент WoW не принимает «@@»).
    </p>

    <form method="post">
        @{
            var modelErrors = ViewData.ModelState[string.Empty]?.Errors;
        }
        @if (modelErrors is { Count: > 0 })
        {
            <div class="alert alert-error" role="alert">
                @foreach (var e in modelErrors)
                {
                    <div>@e.ErrorMessage</div>
                }
            </div>
        }

        <div class="field">
            <label asp-for="Input.Email"></label>
            <input asp-for="Input.Email" autocomplete="email" autofocus />
            <span asp-validation-for="Input.Email" class="field-error"></span>
        </div>
        <div class="field">
            <label asp-for="Input.AccountName"></label>
            <input asp-for="Input.AccountName" autocomplete="off" spellcheck="false" />
            <span asp-validation-for="Input.AccountName" class="field-error"></span>
        </div>
        <div class="field">
            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" type="password" autocomplete="new-password" />
            <span asp-validation-for="Input.Password" class="field-error"></span>
        </div>
        <div class="field">
            <label asp-for="Input.ConfirmPassword"></label>
            <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
            <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn">Зарегистрироваться</button>
        </div>
        <p class="form-hint">Уже есть аккаунт? <a asp-page="/Login">Войти</a></p>
    </form>
</div>
