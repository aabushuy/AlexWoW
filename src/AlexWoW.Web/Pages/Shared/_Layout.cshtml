@using System.Security.Claims
@{
    var isAuth = User.Identity?.IsAuthenticated == true;
    var gameAccount = AuthSession.GameAccount(User);
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AlexWoW</title>
    <link rel="stylesheet" href="~/css/wow.css" asp-append-version="true" />
</head>
<body>
    <div class="page-frame">
        <header class="site-header">
            <a class="brand" asp-page="/Index">
                <span class="brand-mark">⚔</span>
                <span class="brand-text">Alex<span class="brand-accent">WoW</span></span>
            </a>
            <nav class="site-nav">
                @if (isAuth)
                {
                    <a asp-page="/Characters/Index">Персонажи</a>
                    <details class="nav-dropdown">
                        <summary>@gameAccount</summary>
                        <div class="nav-dropdown-menu">
                            <a asp-page="/Account/Index">Аккаунт</a>
                            <a asp-page="/Account/ChangePassword">Сменить пароль</a>
                            <form method="post" asp-page="/Logout">
                                <button type="submit">Выйти</button>
                            </form>
                        </div>
                    </details>
                }
                else
                {
                    <a asp-page="/Login">Логин</a>
                    <a asp-page="/Register">Регистрация</a>
                }
            </nav>
        </header>

        <main class="site-main">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <span>AlexWoW — игровая панель · WotLK 3.3.5a</span>
        </footer>
    </div>
</body>
</html>
