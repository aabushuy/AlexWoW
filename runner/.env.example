# Sample .env для homeserver-runner. Положить как /data/docker/alexwow-runner/.env
# (с реальным PAT, НЕ в git). См. docs/onboarding/runner-setup.md.

# GitHub fine-grained PAT с permissions:
#   Repository → Administration → Read and write (для регистрации runner'а)
#   Repository → Actions → Read-only
#   Repository → Contents → Read-only
# Срок 90 дней, ротация — см. runner-setup.md.
ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Репо, к которому привязан runner.
REPO_URL=https://github.com/aabushuy/AlexWoW

# Имя runner'а, как оно появится в Settings → Actions → Runners.
RUNNER_NAME=homeserver

# scope=repo (привязка к одному репо). org/enterprise — если будем масштабировать на org.
RUNNER_SCOPE=repo

# Labels — селекторы в .github/workflows/ci.yml.
# `self-hosted` и `linux` — стандартные; `deploy` — runner имеет bind-mount к /data/docker/alexwow;
# `dotnet` — есть .NET SDK; `homeserver` — этот конкретный хост.
LABELS=self-hosted,linux,docker,homeserver,deploy,dotnet
