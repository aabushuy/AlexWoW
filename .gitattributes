# Нормализация переводов строк: в репозитории храним LF.
* text=auto eol=lf

# Windows PowerShell-скрипты держим в CRLF (WPS 5.1 капризен).
*.ps1 text eol=crlf

# Бинарные файлы — без преобразований.
*.dll binary
*.exe binary
*.pdb binary
*.png binary
*.jpg binary
*.ico binary
*.mpq binary
*.dbc binary
